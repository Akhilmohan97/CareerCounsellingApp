<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="CareerCounsellingApp.CategoryManagementWindow"
        xmlns:vm="clr-namespace:CareerCounsellingApp.ViewModels"
        x:DataType="vm:CategoryManagementViewModel"
        Width="1200"
        Height="760"
        Title="Category Management"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                Padding="32,24">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="6">
                    <TextBlock Text="Category Management"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Create, update and organize career categories for assessment workflows"
                               FontSize="14"
                               Foreground="#DBEAFE"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FFFFFF20"
                        CornerRadius="999"
                        Padding="14,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="??  Admin Workspace"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1"
                Padding="30"
                Background="{StaticResource BackgroundBrush}">
            <Grid ColumnDefinitions="430,*"
                  ColumnSpacing="24">

                <!-- Left Panel -->
                <Border Grid.Column="0"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="24"
                        CornerRadius="20"
                        BoxShadow="0 10 30 #18000000">

                    <StackPanel Spacing="18">
                        <Border Background="#EFF6FF"
                                Padding="14,12"
                                CornerRadius="12"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Category Details"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Add a new category or update an existing one and link it to the right parent group."
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F8FAFC"
                                Padding="16"
                                CornerRadius="14"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Parent Category"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <ComboBox Height="44"
                                              Padding="12"
                                              ItemsSource="{Binding ParentCat}"
                                              SelectedValue="{Binding SelectedParentCatId}"
                                              SelectedValueBinding="{Binding Id}"
                                              SelectedItem="{Binding SelectedParentCat}"
                                              DisplayMemberBinding="{Binding Name}"/>
                                </StackPanel>

                                <Button Name="AddParentCatBtn"
                                        Height="42"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Command="{Binding AddParentCategoryCommand}"
                                        Classes="accent"
                                        HorizontalAlignment="Stretch">
                                    <TextBlock Text="Add Parent Category"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Category Name"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBox PlaceholderText="Enter category name"
                                     Text="{Binding CategoryName}"
                                     Height="44"
                                     Padding="12" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Description"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBox PlaceholderText="Enter description"
                                     Text="{Binding CategoryDescription}"
                                     Height="100"
                                     Padding="12"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="10">
                            <Button Command="{Binding AddCategoryCommand}"
                                    Height="44"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Classes="accent"
                                    MinWidth="140">
                                <TextBlock Text="Add Category"/>
                            </Button>
                            <Button Command="{Binding UpdateCategoryCommand}"
                                    Height="44"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Classes="primary"
                                    MinWidth="120">
                                <TextBlock Text="Update"/>
                            </Button>
                        </StackPanel>

                        <Button Command="{Binding DeleteCategoryCommand}"
                                Height="44"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Classes="error"
                                HorizontalAlignment="Stretch">
                            <TextBlock Text="Delete Selected Category"/>
                        </Button>

                    </StackPanel>

                </Border>

                <!-- Right Panel -->
                <Border Grid.Column="1"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="24"
                        CornerRadius="20"
                        BoxShadow="0 10 30 #18000000">

                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Spacing="12"
                                    Margin="0,0,0,16">
                            <Border Width="44"
                                    Height="44"
                                    Background="#DBEAFE"
                                    CornerRadius="22">
                                <TextBlock Text="???"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Available Categories"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Select a category to review or update it"
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <ListBox Grid.Row="1"
                                 Margin="0,4,0,0"
                                 ItemsSource="{Binding Categories}"
                                 SelectedItem="{Binding SelectedCategory}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,6"
                                            Padding="16"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12">
                                            <Border Width="40"
                                                    Height="40"
                                                    Background="#E0E7FF"
                                                    CornerRadius="20"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="??"
                                                           FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Spacing="4">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </Grid>

                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
