<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CareerCounsellingApp.PhotoCaptureWindow"
        xmlns:vm="using:CareerCounsellingApp.ViewModels"
        x:DataType="vm:PhotoCaptureViewModel"
        Title="Capture Student Photo">
    <StackPanel Margin="25"
                HorizontalAlignment="Center"
                Spacing="15">

        <TextBlock Text="Scan this QR Code"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <Border
            Width="300"
            Height="300"
            BorderBrush="Gray"
            BorderThickness="1">

            <Image Width="280"
                   Height="280"
                   Source="{Binding QRCode}" />

        </Border>

        <TextBlock
            Text="{Binding Status}"
            HorizontalAlignment="Center"
            FontSize="16"/>

        <TextBlock
            Text="{Binding Countdown}"
            HorizontalAlignment="Center"
            FontWeight="Bold"/>

        <Button
            Width="150"
            Content="Cancel"
            Command="{Binding CancelCommand}" />

    </StackPanel>

</Window>
