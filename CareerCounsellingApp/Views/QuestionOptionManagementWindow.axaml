<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="CareerCounsellingApp.QuestionOptionManagementWindow"
        xmlns:vm="using:CareerCounsellingApp.ViewModels"
        x:DataType="vm:QuestionOptionManagementViewModel"
        Width="900"
        Height="700"
        Title="Question Options"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                Padding="30,20">
            <TextBlock Text="Question Options"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"/>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1"
              Margin="30"
              ColumnDefinitions="350,*"
              ColumnSpacing="30">

            <!-- Left Panel - Form -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    Padding="25"
                    CornerRadius="8"
                    BoxShadow="0 1 3 #00000010">

                <StackPanel Spacing="15">

                    <TextBlock Text="Add Option"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <Separator Height="1" Background="{StaticResource BorderBrush}"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Option Text"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox PlaceholderText="Enter option text"
                                 Text="{Binding OptionText}"
                                 Height="40"
                                 Padding="12" />
                        <TextBlock Text="ഉത്തര ഓപ്ഷൻ"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox PlaceholderText="ഉത്തര ഓപ്ഷൻ നൽകുക"
                                 Text="{Binding OptionTextMalayalam}"
                                 Height="40"
                                 Padding="12" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Score (0-100)"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <NumericUpDown Value="{Binding Score}"
                                       Minimum="0"
                                       Maximum="100"
                                       Height="40"
                                       Padding="12"
                                       FontSize="14"/>
                    </StackPanel>

                    <Separator Height="1" Background="{StaticResource BorderBrush}" Margin="0,10,0,0"/>

                    <StackPanel Orientation="Horizontal"
                                Spacing="10">

                        <Button Command="{Binding AddOptionCommand}"
                                Height="40"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Classes="accent">
                            <TextBlock Text="Add"/>
                        </Button>

                        <Button Command="{Binding UpdateOptionCommand}"
                                Height="40"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Classes="primary">
                            <TextBlock Text="Update"/>
                        </Button>

                        <Button Command="{Binding DeleteOptionCommand}"
                                Height="40"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Classes="error">
                            <TextBlock Text="Delete"/>
                        </Button>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- Right Panel - Options List -->
            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    Padding="25"
                    CornerRadius="8"
                    BoxShadow="0 1 3 #00000010">

                <Grid RowDefinitions="Auto,*">

                    <TextBlock Grid.Row="0"
                               Text="Options"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <ListBox Grid.Row="1"
                             Margin="0,15,0,0"
                             ItemsSource="{Binding Options}"
                             SelectedItem="{Binding SelectedOption}"
                             Background="{StaticResource BackgroundBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,5"
                                        Padding="15"
                                        Background="{StaticResource BackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding OptionText}"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="Score:"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Score}"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>

            </Border>

        </Grid>
    </Grid>

</Window>
