<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
        x:Class="CareerCounsellingApp.ThankYouWindow"
        Width="700"
        Height="500"
        Title="Assessment Submitted"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Border Background="{StaticResource SurfaceBrush}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="30"
                        MaxWidth="500">

                <StackPanel HorizontalAlignment="Center" Spacing="10">
                    <TextBlock Text="✓"
                               FontSize="80"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Assessment Submitted Successfully"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <Separator Height="2" Background="{StaticResource BorderBrush}"/>

                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="Thank you for completing the career assessment."
                               FontSize="16"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Your responses have been securely recorded and will be analyzed to provide you with personalized career recommendations."
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Please contact your counselor for your detailed results and career guidance."
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Button Name="CloseButton"
                        Width="200"
                        Height="45"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        Margin="0,20,0,0"
                        Classes="primary">
                    <TextBlock Text="Close"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </Button>

            </StackPanel>
        </Border>
    </Grid>

</Window>
