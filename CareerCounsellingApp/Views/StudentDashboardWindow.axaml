<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        xmlns:vm="using:CareerCounsellingApp.ViewModels"
        x:Class="CareerCounsellingApp.StudentDashboardWindow"
        x:DataType="vm:StudentDashboardViewModel"
        Width="900"
        Height="600"
        Title="Student Dashboard"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                Padding="30,25">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding WelcomeMessage}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"/>
                
                <!-- Header Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Name="LogoutButton"
                            x:Name="LogoutButton"
                            Width="45"
                            Height="45"
                            CornerRadius="4"
                            Background="White"
                            Foreground="{StaticResource PrimaryBrush}"
                            BorderThickness="0"
                            ToolTip.Tip="Logout"
                            Cursor="Hand">
                        <TextBlock Text="??" FontSize="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1"
                Padding="40">
            <StackPanel 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="40">

                <Border Background="{StaticResource SurfaceBrush}"
                        Padding="40"
                        CornerRadius="8"
                        BoxShadow="0 1 3 #00000010">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Career Assessment"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Take the comprehensive career assessment to receive personalized career guidance and recommendations based on your interests and aptitudes."
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"/>
                        <Button Name="StartAssessmentButton"
                                x:Name="StartAssessmentButton"
                                Height="50"
                                Cursor="Hand"
                                Margin="0,10,0,0"
                                Classes="accent"
                                ToolTip.Tip="Begin the career assessment">
                            <TextBlock Text="Start Assessment" 
                                       FontSize="16" 
                                       FontWeight="SemiBold" 
                                       Foreground="White"/>
                        </Button>
                    </StackPanel>
                </Border>

                <TextBlock Text="Estimated time: 30-45 minutes"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>
