<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CareerCounsellingApp.ViewModels"
    x:Class="CareerCounsellingApp.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Width="950"
    Height="700"
    Title="Career Counselling System"
    Background="#F4F7FC"
    WindowState="Maximized"
    WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="2*,2.5*">

        <!-- LEFT PANEL -->
        <Border Grid.Column="0">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#2563EB"/>
                    <GradientStop Offset="0.5" Color="#1D4ED8"/>
                    <GradientStop Offset="1" Color="#1E3A8A"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="330">

                    <Image
                        Source="/Assets/logo.png"
                        Stretch="Uniform"
                        Margin="0,0,0,25"/>

                    <TextBlock
                        Text="Career Counselling System"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="White"
                        TextAlignment="Center"
                        TextWrapping="Wrap"/>

                    <TextBlock
                        Margin="0,10,0,0"
                        Text="Discover Your Future With Confidence"
                        FontSize="16"
                        Foreground="#E5E7EB"
                        TextAlignment="Center"/>

                    <Border
                        Margin="0,30"
                        Height="1"
                        Background="#50FFFFFF"/>

                    <TextBlock
                        Text="Professional Career Guidance Platform"
                        FontSize="15"
                        Foreground="White"
                        Opacity="0.85"
                        TextAlignment="Center"/>

                    <TextBlock
                        Margin="0,5"
                        Text="Version 1.0.1"
                        FontSize="13"
                        Foreground="White"
                        Opacity="0.7"
                        TextAlignment="Center"/>

                </StackPanel>

                <!-- Footer -->

                <StackPanel
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,25">

                    <TextBlock
                        Text="Powered by"
                        HorizontalAlignment="Center"
                        Foreground="White"
                        Opacity="0.7"
                        FontSize="12"/>

                    <TextBlock
                        Text="www.saikiranz.in"
                        HorizontalAlignment="Center"
                        Foreground="White"
                        FontWeight="SemiBold"
                        FontSize="14"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- RIGHT PANEL -->

        <Grid Grid.Column="1">

            <Border
                Width="420"
                Padding="40"
                CornerRadius="18"
                Background="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <StackPanel Spacing="18">

                    <TextBlock
                        Text="Welcome 👋"
                        FontSize="30"
                        FontWeight="Bold"/>

                    <TextBlock
                        Text="Sign in to continue your assessment journey"
                        FontSize="14"
                        Foreground="Gray"/>

                    <Border
                        Height="1"
                        Background="#E5E7EB"/>

                    <!-- USERNAME -->

                    <StackPanel Spacing="5">

                        <TextBlock
                            Text="👤 Username"
                            FontWeight="SemiBold"/>

                        <TextBox
                            Height="44"
                            Padding="12"
                            FontSize="14"
                            Text="{Binding Username}"
                            PlaceholderText="Enter username"/>

                    </StackPanel>

                    <!-- PASSWORD -->

                    <StackPanel Spacing="5">

                        <TextBlock
                            Text="🔒 Password"
                            FontWeight="SemiBold"/>

                        <TextBox
                            Height="44"
                            Padding="12"
                            PasswordChar="*"
                            FontSize="14"
                            Text="{Binding Password}"
                            PlaceholderText="Enter password"/>

                    </StackPanel>

                    <!-- Loading -->

                    <StackPanel
                        IsVisible="{Binding IsLoading}"
                        Spacing="8">

                        <TextBlock
                            Text="Signing in..."
                            FontWeight="SemiBold"/>

                        <ProgressBar
                            IsIndeterminate="True"
                            Height="6"/>

                    </StackPanel>

                    <!-- Buttons -->

                    <Grid
                        ColumnDefinitions="*,*"
                        ColumnSpacing="12">

                        <Button
                            Grid.Column="0"
                            Height="46"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            Background="#2563EB"
                            Foreground="White"
                            FontWeight="Bold"
                            CornerRadius="8">
                            <TextBlock Text="🔐 Sign In" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <Button
                            Grid.Column="1"
                            Height="46"
                            Command="{Binding ClearCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            Background="#ECEFF3"
                            Foreground="#374151"
                            FontWeight="Bold"
                            CornerRadius="8">
                            <TextBlock Text="🗑 Clear" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                    </Grid>

                    <!-- Error -->

                    <TextBlock
                        Foreground="Red"
                        FontSize="13"
                        Text="{Binding Message}"
                        TextWrapping="Wrap"
                        IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>