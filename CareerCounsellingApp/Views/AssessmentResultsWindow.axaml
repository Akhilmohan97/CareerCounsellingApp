<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="using:CareerCounsellingApp.Models"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="CareerCounsellingApp.AssessmentResultsWindow"
        xmlns:vm="using:CareerCounsellingApp.ViewModels"
        x:DataType="vm:AssessmentResultsViewModel"
        Width="1400"
        Height="800"
        Title="Assessment Results"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Grid RowDefinitions="Auto,*">
      <!-- Header -->
      <Border Grid.Row="0"
              Background="{StaticResource PrimaryBrush}"
              Padding="30,20">
        <TextBlock Text="Assessment Results"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"/>
      </Border>

      <!-- Content -->
      <Grid Grid.Row="1"
            Margin="30"
            ColumnDefinitions="380,*"
            ColumnSpacing="30">

        <!-- Left Panel - Students List -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="25"
                CornerRadius="8"
                BoxShadow="0 1 3 #00000010">

          <Grid RowDefinitions="Auto,*">

            <TextBlock Grid.Row="0"
                       Text="Students"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <ListBox Grid.Row="1"
                     Margin="0,15,0,0"
                     ItemsSource="{Binding Results}"
                     SelectedItem="{Binding SelectedResult}"
                     Background="{StaticResource BackgroundBrush}">

              <ListBox.ItemTemplate>

                <DataTemplate x:DataType="model:StudentAssessmentResult">

                  <Border Margin="0,5"
                          Padding="15"
                          Background="{StaticResource BackgroundBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1"
                          CornerRadius="4">

                    <StackPanel Spacing="5">

                      <TextBlock Text="{Binding StudentName}"
                                 FontWeight="Bold"
                                 FontSize="14"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>

                      <TextBlock Text="{Binding AssessmentDate}"
                                 FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>

                    </StackPanel>

                  </Border>

                </DataTemplate>

              </ListBox.ItemTemplate>

            </ListBox>

          </Grid>

        </Border>

        <!-- Right Panel - Scores Details -->
        <Border Grid.Column="1"
                Background="{StaticResource SurfaceBrush}"
                Padding="25"
                CornerRadius="8"
                BoxShadow="0 1 3 #00000010">

          <Grid RowDefinitions="Auto,*,Auto">

            <TextBlock Grid.Row="0"
                       Text="Category Scores"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <ListBox Grid.Row="1"
                     Margin="0,15,0,0"
                     ItemsSource="{Binding CategoryScores}"
                     Background="{StaticResource BackgroundBrush}">

              <ListBox.ItemTemplate>

                <DataTemplate x:DataType="model:CategoryScore">

                  <Border Margin="0,5"
                          Padding="15"
                          Background="{StaticResource BackgroundBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1"
                          CornerRadius="4">

                    <Grid ColumnDefinitions="*,120">

                      <StackPanel>
                        <TextBlock Text="{Binding CategoryName}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                      </StackPanel>

                      <Border Grid.Column="1"
                              Background="{StaticResource AccentBrush}"
                              CornerRadius="4"
                              Padding="12,6"
                              HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Score}"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   FontSize="14"/>
                      </Border>

                    </Grid>

                  </Border>

                </DataTemplate>

              </ListBox.ItemTemplate>

            </ListBox>

            <!-- Highest Category -->
            <Border Grid.Row="2"
                    Margin="0,20,0,0"
                    Padding="20"
                    Background="{StaticResource PrimaryLightColor}"
                    CornerRadius="6">

              <StackPanel Spacing="8">

                <TextBlock Text="Highest Category"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Opacity="0.9"/>

                <TextBlock Text="{Binding HighestCategory}"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"/>

              </StackPanel>

            </Border>

          </Grid>

        </Border>

      </Grid>
    </Grid>
</Window>
