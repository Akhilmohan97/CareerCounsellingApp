<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="400"
        x:Class="CareerCounsellingApp.AlreadySubmittedWindow"
        Width="700"
        Height="400"
        Title="Assessment Already Completed"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Border Background="{StaticResource SurfaceBrush}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="30"
                        MaxWidth="500">

                <StackPanel HorizontalAlignment="Center" Spacing="10">
                    <TextBlock Text="?"
                               FontSize="80"
                               Foreground="{StaticResource WarningColor}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Assessment Already Completed"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <Separator Height="2" Background="{StaticResource BorderBrush}"/>

                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="You have already completed this assessment."
                               FontSize="16"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Each student can only submit the assessment once. If you need to retake the assessment or have questions, please contact the administrator for further assistance."
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Button Name="CloseButton"
                        Width="200"
                        Height="45"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        Margin="0,20,0,0"
                        Classes="primary">
                    <TextBlock Text="Close"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </Button>

            </StackPanel>
        </Border>
    </Grid>

</Window>
