<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CareerCounsellingApp.AlreadySubmittedWindow"
        Width="600"
        Height="300"
        Title="Assessment Already Completed">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="20">

        <TextBlock Text="Assessment Already Completed"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <TextBlock Text="You have already completed this assessment."
                   FontSize="18"
                   HorizontalAlignment="Center"/>

        <TextBlock Text="Please contact the administrator for further assistance."
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"/>

        <Button Name="CloseButton"
                Width="150"
                Height="40">

            <TextBlock Text="Close"/>

        </Button>

    </StackPanel>
</Window>
