<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CareerCounsellingApp.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="CareerCounsellingApp.StudentManagementWindow"
        x:DataType="vm:StudentManagementViewModel"
        Width="1400"
        Height="800"
        Title="Student Management"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Grid RowDefinitions="Auto,*">
      <!-- Header -->
      <Border Grid.Row="0"
              Background="{StaticResource PrimaryBrush}"
              Padding="30,20">
        <TextBlock Text="Student Management"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"/>
      </Border>

      <!-- Content -->
      <Grid Grid.Row="1"
            Margin="30"
            ColumnDefinitions="500,*"
            ColumnSpacing="30">

        <!-- Left Panel -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="25"
                CornerRadius="8"
                BoxShadow="0 1 3 #00000010">

          <ScrollViewer>
            <StackPanel Spacing="15">

              <TextBlock Text="Student Details"
                         FontSize="20"
                         FontWeight="Bold"
                         Foreground="{StaticResource TextPrimaryBrush}"/>

              <Separator Height="1" Background="{StaticResource BorderBrush}"/>

              <!-- Photo -->
              <Border Width="180"
                      Height="180"
                      HorizontalAlignment="Center"
                      Background="{StaticResource BackgroundBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="2"
                      CornerRadius="4">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="?? Photo"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
              </Border>

              <Button Name="BrowsePhotoButton"
                      Height="40"
                      Foreground="White"
                      FontWeight="SemiBold"
                      HorizontalAlignment="Center"
                      Cursor="Hand"
                      Classes="primary">
                <TextBlock Text="Browse Photo"/>
              </Button>

              <StackPanel Spacing="4">
                <TextBlock Text="Admission Number"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox PlaceholderText="Enter admission number"
                         Text="{Binding AdmissionNo}"
                         Height="40"
                         Padding="12" />
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Full Name"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox PlaceholderText="Enter full name"
                         Text="{Binding FullName}"
                         Height="40"
                         Padding="12" />
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Gender"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <ComboBox SelectedItem="{Binding Gender}"
                          Height="40"
                          Padding="12">
                  <ComboBoxItem Content="Male"/>
                  <ComboBoxItem Content="Female"/>
                  <ComboBoxItem Content="Other"/>
                </ComboBox>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Email"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox PlaceholderText="Enter email"
                         Text="{Binding Email}"
                         Height="40"
                         Padding="12" />
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Course"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox PlaceholderText="Enter course"
                         Text="{Binding Course}"
                         Height="40"
                         Padding="12" />
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Institution"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox PlaceholderText="Enter institution"
                         Text="{Binding Institution}"
                         Height="40"
                         Padding="12" />
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Username"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox PlaceholderText="Enter username"
                         Text="{Binding Username}"
                         Height="40"
                         Padding="12" />
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Password"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox PlaceholderText="Enter password"
                         Text="{Binding Password}"
                         Height="40"
                         Padding="12" />
              </StackPanel>

              <Separator Height="1" Background="{StaticResource BorderBrush}" Margin="0,10,0,0"/>

              <StackPanel Orientation="Horizontal"
                          Spacing="10">

                <Button Height="45"
                        Command="{Binding AddStudentCommand}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Classes="accent">
                  <TextBlock Text="Add"/>
                </Button>

                <Button Height="45"
                        Command="{Binding UpdateStudentCommand}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Classes="primary">
                  <TextBlock Text="Update"/>
                </Button>

                <Button Height="45"
                        Command="{Binding DeleteStudentCommand}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Classes="error">
                  <TextBlock Text="Delete"/>
                </Button>

              </StackPanel>

            </StackPanel>
          </ScrollViewer>

        </Border>

        <!-- Right Panel -->
        <Border Grid.Column="1"
                Background="{StaticResource SurfaceBrush}"
                Padding="25"
                CornerRadius="8"
                BoxShadow="0 1 3 #00000010">

          <Grid RowDefinitions="Auto,*">

            <TextBlock Grid.Row="0"
                       Text="Students"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <ListBox Grid.Row="1"
                     Margin="0,15,0,0"
                     ItemsSource="{Binding Students}"
                     SelectedItem="{Binding SelectedStudent}"
                     Background="{StaticResource BackgroundBrush}">

              <ListBox.ItemTemplate>

                <DataTemplate>

                  <Border Margin="0,5"
                          Padding="15"
                          Background="{StaticResource BackgroundBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1"
                          CornerRadius="4"
                          Cursor="Hand">

                    <Grid ColumnDefinitions="90,*" ColumnSpacing="15">

                      <Border Grid.Column="0"
                              Width="70"
                              Height="70"
                              Background="{StaticResource BackgroundBrush}"
                              BorderBrush="{StaticResource BorderBrush}"
                              BorderThickness="1"
                              CornerRadius="4">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="??"
                                   FontSize="24"/>
                      </Border>

                      <StackPanel Grid.Column="1" Spacing="4">

                        <TextBlock Text="{Binding FullName}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <TextBlock Text="{Binding AdmissionNo}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                        <TextBlock Text="{Binding Course}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                        <TextBlock Text="{Binding Institution}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                      </StackPanel>

                    </Grid>

                  </Border>

                </DataTemplate>

              </ListBox.ItemTemplate>

            </ListBox>

          </Grid>

        </Border>

      </Grid>
    </Grid>

</Window>
