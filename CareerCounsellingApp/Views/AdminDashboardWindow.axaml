<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CareerCounsellingApp.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1300" d:DesignHeight="700"
        x:Class="CareerCounsellingApp.AdminDashboardWindow"
        x:DataType="vm:AdminDashboardViewModel"
        Title="Admin Dashboard"
        WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.ColumnSpan="2"
                Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="30,20">
            <Grid
                ColumnDefinitions="*,Auto"
                Margin="10">

                <StackPanel>

                    <TextBlock
                        Text="Admin Dashboard"
                        FontSize="30"
                        FontWeight="Bold"/>

                    <TextBlock
                        Text="Manage students, questions and assessments"
                        Foreground="Gray"
                        FontSize="14"/>

                </StackPanel>

                <Button
                    Grid.Column="1"
                    CornerRadius="22">

                    <TextBlock
                        Text="🔄"
                        FontSize="18"/>

                </Button>

            </Grid>
        </Border>

        <!-- Sidebar -->
        <Border
            Grid.Column="0"
            Grid.RowSpan="2"
            Grid.Row="1"
            Background="#1E3A8A">

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Branding -->
                <StackPanel
                    Margin="20"
                    HorizontalAlignment="Center"
                    Spacing="5">

                    <Image
                        Source="/Assets/logo.png"
                        Width="120"
                        Height="150"/>

                    <TextBlock
                        Text="Career Counselling"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        HorizontalAlignment="Center"/>

                    <TextBlock
                        Text="Administration"
                        FontSize="13"
                        Foreground="#D1D5DB"
                        HorizontalAlignment="Center"/>

                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1"
                            Margin="10"
                            Spacing="8">
                    <StackPanel Spacing="2">
                        <Button
                            Name="CategoryButton"
                            Height="52"
                            Width="230"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="12"
                            HorizontalContentAlignment="Left"
                            Padding="18,0">

                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="12">

                                <TextBlock
                                    Text="📂"
                                    FontSize="18"/>

                                <TextBlock
                                    Text="Manage Categories"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="White"/>

                            </StackPanel>

                        </Button>

                        <Button Name="QuestionButton"
                                Height="52"
                                Background="Transparent"
                                CornerRadius="12"
                                Width="230"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="0"
                                Padding="18,0"
                                HorizontalContentAlignment="Left"
                                Cursor="Hand"
                                ToolTip.Tip="Add and manage assessment questions">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="12">

                                <TextBlock
                                    Text="❓"
                                    FontSize="18"/>

                                <TextBlock
                                    Text="Manage Questions"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="White"/>

                            </StackPanel>
                        </Button>

                        <Button Name="StudentButton"
                                Height="52"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="0"
                                Padding="18,0"
                                HorizontalContentAlignment="Left"
                                Cursor="Hand"
                                ToolTip.Tip="Manage student information">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="12">

                                <TextBlock
                                    Text="👨‍🎓"
                                    FontSize="18"/>

                                <TextBlock
                                    Text="Manage Students"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="White"/>

                            </StackPanel>
                        </Button>

                        <Button Name="AssessmentResultsButton"
                                Height="52"
                                Width="230"
                                Foreground="White"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="18,0"
                                HorizontalContentAlignment="Left"
                                Cursor="Hand"
                                ToolTip.Tip="View student assessment results and scores">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="12">

                                <TextBlock
                                    Text="📊"
                                    FontSize="18"/>

                                <TextBlock
                                    Text="Assessment Results"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="White"/>

                            </StackPanel>
                        </Button>

                        <Button Height="52"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="18,0"
                                Background="Transparent"
                                Width="230"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Cursor="Hand"
                                ToolTip.Tip="Generate system reports">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="12">

                                <TextBlock
                                    Text="📈"
                                    FontSize="18"/>

                                <TextBlock
                                    Text="Reports"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="White"/>

                            </StackPanel>
                        </Button>

                        <Separator Height="1" Background="White" Opacity="0.2" Margin="0,20"/>

                        <Button Name="LogoutButton"
                                Height="52"
                                Background="Transparent"
                                Width="230"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="0"
                                Padding="18,0"
                                HorizontalContentAlignment="Left"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                ToolTip.Tip="Logout and return to login screen">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="12">

                                <TextBlock
                                    Text="🚪"
                                    FontSize="18"/>

                                <TextBlock
                                    Text="Logout"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="White"/>

                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <!-- Buttons here -->

                </StackPanel>

            </Grid>

        </Border>
        <!-- <Border Grid.Column="0"
        Grid.Row="1"
        Background="{StaticResource PrimaryDarkColor}"
        Padding="0">
        <StackPanel Spacing="2">
        <Button Name="CategoryButton"
        Height="60"
        Foreground="White"
        BorderThickness="0"
        Margin="0"
        Padding="20,15"
