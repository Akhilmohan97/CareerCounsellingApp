        </Button>
        </StackPanel>
        </Border>-->

        <!-- Main Content Area -->
        <Border Grid.Column="1"
                Grid.Row="1"
                Background="{StaticResource BackgroundBrush}"
                Padding="40">
            <ScrollViewer>
                <StackPanel Spacing="30">
                    <!-- Welcome Section -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Welcome to Admin Dashboard"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Here's an overview of your Career Counselling System"
                                   FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Statistics Grid -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="20" RowSpacing="20">

                        <!-- Total Students Card -->
                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Background="White"
                                CornerRadius="18"
                                Padding="28"
                                MinHeight="180"
                                BorderBrush="#2563EB"
                                BorderThickness="5,0,0,0"
                                BoxShadow="0 10 30 #18000000">

                            <StackPanel Spacing="18">

                                <Grid ColumnDefinitions="Auto,*">

                                    <Border Width="55"
                                            Height="55"
                                            Background="#DBEAFE"
                                            CornerRadius="28">

                                        <TextBlock
                                            Text="👨‍🎓"
                                            FontSize="26"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="15,0,0,0">

                                        <TextBlock
                                            Text="Total Students"
                                            FontSize="18"
                                            FontWeight="SemiBold"/>

                                        <TextBlock
                                            Text="Registered Students"
                                            FontSize="12"
                                            Foreground="Gray"/>

                                    </StackPanel>

                                </Grid>

                                <TextBlock
                                    Text="{Binding TotalStudents}"
                                    FontSize="52"
                                    FontWeight="Bold"
                                    Foreground="#2563EB"/>

                            </StackPanel>

                        </Border>

                        <!-- Students Assessed Card -->
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Background="White"
                                CornerRadius="18"
                                Padding="28"
                                MinHeight="180"
                                BorderBrush="#10B981"
                                BorderThickness="5,0,0,0"
                                BoxShadow="0 10 30 #18000000">

                            <StackPanel Spacing="18">

                                <Grid ColumnDefinitions="Auto,*">

                                    <Border Width="55"
                                            Height="55"
                                            Background="#D1FAE5"
                                            CornerRadius="28">

                                        <TextBlock
                                            Text="✅"
                                            FontSize="24"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="15,0,0,0">

                                        <TextBlock
                                            Text="Students Assessed"
                                            FontSize="18"
                                            FontWeight="SemiBold"/>

                                        <TextBlock
                                            Text="Completed Assessment"
                                            FontSize="12"
                                            Foreground="Gray"/>

                                    </StackPanel>

                                </Grid>

                                <TextBlock
                                    Text="{Binding StudentsAssessed}"
                                    FontSize="52"
                                    FontWeight="Bold"
                                    Foreground="#10B981"/>

                            </StackPanel>

                        </Border>

                        <!-- Total Questions Card -->
                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Background="White"
                                CornerRadius="18"
                                Padding="28"
                                MinHeight="180"
                                BorderBrush="#F59E0B"
                                BorderThickness="5,0,0,0"
                                BoxShadow="0 10 30 #18000000">

                            <StackPanel Spacing="18">

                                <Grid ColumnDefinitions="Auto,*">

                                    <Border Width="55"
                                            Height="55"
                                            Background="#FEF3C7"
                                            CornerRadius="28">

                                        <TextBlock
                                            Text="❓"
                                            FontSize="24"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="15,0,0,0">

                                        <TextBlock
                                            Text="Total Questions"
                                            FontSize="18"
                                            FontWeight="SemiBold"/>

                                        <TextBlock
                                            Text="Assessment Questions"
                                            FontSize="12"
                                            Foreground="Gray"/>

                                    </StackPanel>

                                </Grid>

                                <TextBlock
                                    Text="{Binding TotalQuestions}"
                                    FontSize="52"
                                    FontWeight="Bold"
                                    Foreground="#F59E0B"/>

                            </StackPanel>

                        </Border>

                        <!-- Total Categories Card -->
                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Background="White"
                                CornerRadius="18"
                                Padding="28"
                                MinHeight="180"
                                BorderBrush="#8B5CF6"
                                BorderThickness="5,0,0,0"
                                BoxShadow="0 10 30 #18000000">

                            <StackPanel Spacing="18">

                                <Grid ColumnDefinitions="Auto,*">

                                    <Border Width="55"
                                            Height="55"
                                            Background="#EDE9FE"
                                            CornerRadius="28">

                                        <TextBlock
                                            Text="📂"
                                            FontSize="24"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="15,0,0,0">

                                        <TextBlock
                                            Text="Total Categories"
                                            FontSize="18"
                                            FontWeight="SemiBold"/>

                                        <TextBlock
                                            Text="Career Categories"
                                            FontSize="12"
                                            Foreground="Gray"/>

                                    </StackPanel>

                                </Grid>

                                <TextBlock
                                    Text="{Binding TotalCategories}"
                                    FontSize="52"
                                    FontWeight="Bold"
                                    Foreground="#8B5CF6"/>

                            </StackPanel>

                        </Border>

                    </Grid>

                    <!-- Additional Info Section -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            Padding="25"
                            CornerRadius="8"
                            BoxShadow="0 1 3 #00000010">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Quick Actions"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Use the navigation menu on the left to manage categories, questions, students, and view assessment results."
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <Separator Height="1" Background="{StaticResource BorderBrush}" Margin="0,10,0,0"/>
                            <TextBlock Text="?? Tip: Ensure all required data is properly configured before students begin their assessments."
                                       FontSize="13"
                                       Foreground="{StaticResource PrimaryColor}"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
